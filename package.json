{
  "name": "@eda-labs/screenshotter",
  "version": "0.1.0",
  "description": "Capture themed (dark/light) screenshots of the Nokia EDA (Event Driven Automation) web UI.",
  "type": "module",
  "bin": {
    "edascr": "./dist/capture.js",
    "eda-screenshotter": "./dist/capture.js"
  },
  "main": "dist/capture.js",
  "types": "dist/capture.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "capture": "pnpm run build && node dist/capture.js",
    "start": "pnpm run capture",
    "help": "pnpm run build && node dist/capture.js --help",
    "check": "tsc --noEmit",
    "prepare": "pnpm run build",
    "install-browser": "playwright-core install chromium"
  },
  "keywords": [
    "eda",
    "nokia",
    "event-driven-automation",
    "screenshot",
    "playwright",
    "srlinux"
  ],
  "license": "Apache-2.0",
  "author": "eda-labs contributors",
  "homepage": "https://github.com/eda-labs/screenshotter#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eda-labs/screenshotter.git"
  },
  "bugs": {
    "url": "https://github.com/eda-labs/screenshotter/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@11.3.0",
  "dependencies": {
    "playwright-core": "^1.60.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3"
  }
}
